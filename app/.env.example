# Copy to .env and fill in (never commit .env)
# cp app/.env.example app/.env
#
# If app/ is NOT next to public_html/, set on the server (not in .env — too late for bootstrap):
# Apache: SetEnv APP_ROOT_OVERRIDE /absolute/path/to/app
# php-fpm: env[APP_ROOT_OVERRIDE] = /absolute/path/to/app

APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_LOG_ALERT_EMAIL=
APP_LOG_ALERT_THROTTLE_SECONDS=300
APP_URL=https://aleksandar.pro
APP_KEY=
SITE_LANGUAGE_MODE=multi
VIEW_CACHE=true
CORS_ALLOWED_ORIGINS=https://aleksandar.pro
CORS_ALLOW_CREDENTIALS=false

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_CHARSET=utf8mb4

SESSION_LIFETIME=120
BRAND_NAME=aleksandar.pro
BRAND_TAGLINE=Dark Protocol

# Optional: Vite HMR when APP_DEBUG=true on localhost
# VITE_DEV_SERVER_ORIGIN=http://localhost:5173
