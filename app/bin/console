#!/usr/bin/env php
<?php

declare(strict_types=1);

use App\Core\cache\Cache;
use App\Core\database\Database;
use App\Core\database\DatabaseBuilder;
use App\Core\permissions\PermissionRegistry;
use App\Core\routing\DynamicRouteRegistry;
use App\Models\Language;
use App\Models\Page;
use App\Models\Role;
use App\Models\User;

$appPath = dirname(__DIR__);

require_once $appPath . '/bootstrap/app.php';
ap_bootstrap_cli_application($appPath);

$argv = $_SERVER['argv'] ?? [];
$command = $argv[1] ?? 'help';
$options = ap_console_parse_options(array_slice($argv, 2));

try {
    $exitCode = match ($command) {
        'help', '--help', '-h' => ap_console_show_help(),
        'install:setup' => ap_console_install_setup($appPath, $options),
        'install:check' => ap_console_install_check($appPath),
        'storage:prepare' => ap_console_storage_prepare($appPath),
        'cache:clear' => ap_console_cache_clear($appPath),
        'app:key' => ap_console_app_key($appPath, $options),
        'db:migrate' => ap_console_db_migrate($appPath, $options),
        'db:seed' => ap_console_db_seed($options),
        default => ap_console_unknown_command($command),
    };
} catch (Throwable $e) {
    fwrite(STDERR, "[ERROR] {$e->getMessage()}\n");
    exit(1);
}

exit($exitCode);

function ap_console_show_help(): int
{
    echo "Aleksandar.pro console\n\n";
    echo "Usage:\n";
    echo "  php app/bin/console <command> [options]\n\n";
    echo "Commands:\n";
    echo "  install:setup [--mode=hosting|local] [--domain=<domain>] [--site-name=<name>] [--public-path=<path>] [--force]\n";
    echo "                                Prepare public_html, .env, storage and hosting diagnostics\n";
    echo "  install:check                 Check PHP, extensions, .env, storage and DB connectivity\n";
    echo "  storage:prepare               Create storage/cache/log/upload directories\n";
    echo "  cache:clear                   Clear file cache, compiled views and dynamic route cache\n";
    echo "  app:key [--force]             Generate or rotate APP_KEY in app/.env\n";
    echo "  db:migrate [--baseline]       Run pending migrations and store them in schema_migrations\n";
    echo "  db:migrate --baseline         Mark all current migration files as already applied\n";
    echo "  db:seed [--demo]              Seed system data and optionally demo content\n\n";
    echo "db:seed options:\n";
    echo "  --admin-email=<email>\n";
    echo "  --admin-password=<password>\n";
    echo "  --admin-username=<username>\n";
    echo "  --demo                        Also seed demo content\n";

    return 0;
}

function ap_console_unknown_command(string $command): int
{
    fwrite(STDERR, "Unknown command: {$command}\n\n");
    ap_console_show_help();

    return 1;
}

function ap_console_install_setup(string $appPath, array $options): int
{
    $mode = strtolower((string) ($options['mode'] ?? 'hosting'));
    $projectRoot = dirname($appPath);
    $publicPath = ap_console_resolve_public_path($projectRoot, (string) ($options['public-path'] ?? ''));
    $domain = trim((string) ($options['domain'] ?? basename($projectRoot)));
    $siteName = trim((string) ($options['site-name'] ?? $options['brand-name'] ?? $domain));
    $force = !empty($options['force']);

    if (!in_array($mode, ['local', 'hosting'], true)) {
        fwrite(STDERR, "[FAIL] Unsupported install mode '{$mode}'. Use --mode=local or --mode=hosting.\n");
        return 1;
    }

    echo "[INFO] MVC Forge install setup\n";
    echo "[INFO] Mode: {$mode}\n";
    echo "[INFO] App path: {$appPath}\n";
    echo "[INFO] Public path: {$publicPath}\n";
    echo "[INFO] Domain: {$domain}\n";
    echo "[INFO] Site name: {$siteName}\n\n";

    $failed = 0;
    $failed += ap_console_prepare_public_html($appPath, $publicPath, $force);
    $failed += ap_console_prepare_env_file($appPath, $domain, $siteName);
    $failed += ap_console_storage_prepare($appPath);
    $failed += ap_console_ensure_app_key($appPath);

    if ($mode === 'hosting') {
        $failed += ap_console_hosting_diagnostics($appPath, $publicPath, $domain);
    }

    echo "\n";
    if ($failed > 0) {
        echo "[FAIL] install:setup completed with {$failed} issue(s)\n";
        echo "[INFO] Fix the reported items, then run `php app/bin/console install:setup --mode={$mode}` again.\n";
        return 1;
    }

    echo "[OK] install:setup completed\n";
    echo "[NEXT] Review app/.env, then run:\n";
    echo "       php app/bin/console install:check\n";
    echo "       php app/bin/console db:migrate --seed --admin-email=admin@{$domain} --admin-username=admin\n";
    echo "       php app/bin/console cache:clear\n";

    return 0;
}

function ap_console_install_check(string $appPath): int
{
    $failed = 0;

    $failed += ap_console_check('PHP version >= 8.2', version_compare(PHP_VERSION, '8.2.0', '>='));

    foreach (['pdo', 'pdo_mysql', 'json', 'mbstring', 'openssl', 'fileinfo'] as $extension) {
        $failed += ap_console_check("PHP extension {$extension}", extension_loaded($extension));
    }

    $failed += ap_console_check('.env exists', is_file($appPath . '/.env'));
    $failed += ap_console_check('public_html/index.php exists', is_file(dirname($appPath) . '/public_html/index.php'));

    foreach (ap_console_storage_directories($appPath) as $dir) {
        $failed += ap_console_check("Writable directory {$dir}", is_dir($dir) && is_writable($dir));
    }

    try {
        $row = Database::selectOne('SELECT 1 AS ok');
        $dbOk = (int) ($row['ok'] ?? 0) === 1;
    } catch (Throwable) {
        $dbOk = false;
    }

    $failed += ap_console_check('Database connection', $dbOk);

    echo "\n";
    echo $failed === 0
        ? "[OK] install:check passed\n"
        : "[FAIL] install:check has {$failed} issue(s)\n";

    return $failed === 0 ? 0 : 1;
}

function ap_console_storage_prepare(string $appPath): int
{
    $failed = 0;

    foreach (ap_console_storage_directories($appPath) as $dir) {
        if (!is_dir($dir)) {
            @mkdir($dir, 0775, true);
        }

        if (is_dir($dir)) {
            @chmod($dir, 0775);
        }

        $failed += ap_console_check("Prepared {$dir}", is_dir($dir) && is_writable($dir));
    }

    return $failed === 0 ? 0 : 1;
}

function ap_console_cache_clear(string $appPath): int
{
    DynamicRouteRegistry::clearCache();
    $deletedCacheEntries = Cache::flush();
    $deletedViewFiles = ap_console_delete_files($appPath . '/storage/cache/views', '/\\.(php|tmp)$/');

    echo "[OK] Dynamic route cache cleared\n";
    echo "[OK] File cache entries deleted: {$deletedCacheEntries}\n";
    echo "[OK] Compiled views deleted: {$deletedViewFiles}\n";

    return 0;
}

function ap_console_app_key(string $appPath, array $options): int
{
    $envPath = $appPath . '/.env';
    if (!is_file($envPath)) {
        fwrite(STDERR, "[FAIL] {$envPath} not found. Copy app/.env.example to app/.env first.\n");
        return 1;
    }

    $envContent = (string) file_get_contents($envPath);
    $hasExistingKey = preg_match('/^APP_KEY=(.+)$/m', $envContent) === 1;

    if ($hasExistingKey && empty($options['force'])) {
        fwrite(STDERR, "[ABORT] APP_KEY already exists. Use --force to rotate it.\n");
        return 1;
    }

    $appKey = 'base64:' . base64_encode(random_bytes(32));
    if ($hasExistingKey) {
        $envContent = preg_replace('/^APP_KEY=.*/m', 'APP_KEY=' . $appKey, $envContent);
    } else {
        $envContent = rtrim($envContent) . "\nAPP_KEY={$appKey}\n";
    }

    if ($envContent === null || file_put_contents($envPath, $envContent, LOCK_EX) === false) {
        fwrite(STDERR, "[FAIL] Could not write APP_KEY to {$envPath}\n");
        return 1;
    }

    echo "[OK] APP_KEY written to {$envPath}\n";
    return 0;
}

function ap_console_db_migrate(string $appPath, array $options): int
{
    ap_console_ensure_schema_migrations_table();

    $migrationFiles = glob($appPath . '/core/database/migrations/*.php') ?: [];
    sort($migrationFiles, SORT_STRING);

    $appliedRows = Database::select('SELECT migration FROM schema_migrations ORDER BY migration ASC');
    $applied = array_fill_keys(array_column($appliedRows, 'migration'), true);

    $tables = array_values(array_diff(DatabaseBuilder::getTables(), ['schema_migrations']));
    $isBaseline = (bool) ($options['baseline'] ?? false);

    if ($isBaseline) {
        foreach ($migrationFiles as $migrationFile) {
            ap_console_mark_migration_applied(basename($migrationFile));
        }

        echo "[OK] Baseline recorded for " . count($migrationFiles) . " migration file(s)\n";
        return 0;
    }

    if ($tables !== [] && $applied === []) {
        fwrite(STDERR, "[ABORT] Existing tables detected but schema_migrations is empty.\n");
        fwrite(STDERR, "Run `php app/bin/console db:migrate --baseline` once if this is an existing install.\n");
        return 1;
    }

    $executed = 0;
    foreach ($migrationFiles as $migrationFile) {
        $migrationName = basename($migrationFile);
        if (isset($applied[$migrationName])) {
            echo "[SKIP] {$migrationName}\n";
            continue;
        }

        echo "[RUN] {$migrationName}\n";
        ob_start();
        ap_console_execute_migration_file($migrationFile);
        $migrationOutput = trim((string) ob_get_clean());

        if ($migrationOutput !== '') {
            echo $migrationOutput . "\n";
        }

        ap_console_mark_migration_applied($migrationName);
        $executed++;
        echo "[OK] {$migrationName}\n";
    }

    echo "[OK] db:migrate completed, executed {$executed} migration(s)\n";

    if (!empty($options['seed'])) {
        return ap_console_db_seed($options);
    }

    return 0;
}

function ap_console_db_seed(array $options): int
{
    ap_console_seed_system_data($options);

    if (!empty($options['demo'])) {
        ap_console_seed_demo_data();
    }

    echo "[OK] db:seed completed\n";

    return 0;
}

function ap_console_seed_system_data(array $options): void
{
    PermissionRegistry::loadDefaults();
    try {
        PermissionRegistry::sync();
    } catch (Throwable) {
        // Continue if permissions table is not ready in partial installs.
    }

    $role = Role::findBySlug('super-admin');
    if (!$role) {
        $role = Role::create([
            'name' => 'Super Admin',
            'slug' => 'super-admin',
            'description' => 'Full system access',
            'is_system' => 1,
            'priority' => 1,
        ]);
        echo "[OK] Created role super-admin\n";
    } else {
        echo "[SKIP] Role super-admin already exists\n";
    }

    $language = Language::findByCode('sr');
    if (!$language) {
        $language = Language::create([
            'code' => 'sr',
            'name' => 'Serbian',
            'native_name' => 'Srpski',
            'flag' => 'rs',
            'country_code' => 'RS',
            'is_active' => 1,
            'is_site_language' => 1,
            'is_default' => 1,
            'sort_order' => 1,
        ]);
        echo "[OK] Created default language sr\n";
    } else {
        echo "[SKIP] Language sr already exists\n";
    }

    if (!Page::findByRoute('/', 'sr')) {
        Page::create([
            'title' => 'Pocetna',
            'slug' => 'pocetna',
            'route' => '/',
            'page_type' => 'custom',
            'application' => 'homepage',
            'content' => '<h1>Pocetna</h1>',
            'is_active' => 1,
            'is_in_menu' => 0,
            'menu_order' => 0,
            'language_id' => $language?->id,
        ]);
        echo "[OK] Created homepage route /\n";
    } else {
        echo "[SKIP] Homepage route / already exists\n";
    }

    $adminEmail = (string) ($options['admin-email'] ?? $_ENV['APP_SEED_ADMIN_EMAIL'] ?? 'admin@example.com');
    $adminUsername = (string) ($options['admin-username'] ?? $_ENV['APP_SEED_ADMIN_USERNAME'] ?? 'admin');
    $adminPassword = (string) ($options['admin-password'] ?? $_ENV['APP_SEED_ADMIN_PASSWORD'] ?? '');

    if ($adminPassword === '') {
        $adminPassword = 'Ap!' . bin2hex(random_bytes(8));
    }

    $admin = User::findByEmail($adminEmail);
    if (!$admin) {
        $admin = User::createUser([
            'first_name' => 'Admin',
            'last_name' => 'User',
            'username' => $adminUsername,
            'email' => $adminEmail,
            'password' => $adminPassword,
            'status' => 'active',
            'email_verified_at' => time(),
        ]);
        echo "[OK] Created admin user {$adminEmail}\n";
        echo "[INFO] Admin password: {$adminPassword}\n";
    } else {
        echo "[SKIP] Admin user {$adminEmail} already exists\n";
    }

    if ($admin && $role && !$admin->hasRole('super-admin')) {
        $admin->attachRole($role);
        echo "[OK] Attached super-admin role to {$adminEmail}\n";
    }
}

function ap_console_seed_demo_data(): void
{
    $language = Language::findByCode('sr') ?? Language::getDefault();
    $languageId = $language?->id;

    if (Page::findByRoute('/demo', 'sr')) {
        echo "[SKIP] Demo page /demo already exists\n";
        return;
    }

    Page::create([
        'title' => 'Demo stranica',
        'slug' => 'demo',
        'route' => '/demo',
        'page_type' => 'custom',
        'application' => 'demo',
        'content' => '<h1>Demo stranica</h1><p>Primer sadržaja iz opcionog demo seed-a.</p>',
        'is_active' => 1,
        'is_in_menu' => 1,
        'menu_order' => 99,
        'language_id' => $languageId,
    ]);

    echo "[OK] Created demo page /demo\n";
}

function ap_console_ensure_schema_migrations_table(): void
{
    $driver = Database::getDriver();

    if ($driver === 'pgsql') {
        Database::execute(
            'CREATE TABLE IF NOT EXISTS schema_migrations (
                id SERIAL PRIMARY KEY,
                migration VARCHAR(255) NOT NULL UNIQUE,
                migrated_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP
            )'
        );
        return;
    }

    Database::execute(
        'CREATE TABLE IF NOT EXISTS schema_migrations (
            id INT AUTO_INCREMENT PRIMARY KEY,
            migration VARCHAR(255) NOT NULL UNIQUE,
            migrated_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP
        ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci'
    );
}

function ap_console_mark_migration_applied(string $migrationName): void
{
    if (Database::table('schema_migrations')->where('migration', $migrationName)->exists()) {
        return;
    }

    Database::table('schema_migrations')->insert([
        'migration' => $migrationName,
        'migrated_at' => date('Y-m-d H:i:s'),
    ]);
}

function ap_console_execute_migration_file(string $migrationFile): void
{
    $declaredBefore = get_declared_classes();
    require $migrationFile;
    $newClasses = array_diff(get_declared_classes(), $declaredBefore);
    $executedClasses = [];

    foreach ($newClasses as $className) {
        $normalizedClass = ltrim($className, '\\');
        if (!str_starts_with($normalizedClass, 'Migration_') && !str_contains($normalizedClass, '\\Migration_')) {
            continue;
        }

        $reflection = new ReflectionClass($className);
        if (!$reflection->isInstantiable() || !$reflection->hasMethod('up')) {
            continue;
        }

        $sourceFile = $reflection->getFileName();
        if ($sourceFile === false || realpath($sourceFile) !== realpath($migrationFile)) {
            continue;
        }

        $canonicalClass = $reflection->getName();
        if (isset($executedClasses[$canonicalClass])) {
            continue;
        }

        $constructor = $reflection->getConstructor();
        if ($constructor && $constructor->getNumberOfRequiredParameters() > 0) {
            throw new RuntimeException("Migration class {$canonicalClass} requires constructor arguments.");
        }

        $reflection->newInstance()->up();
        $executedClasses[$canonicalClass] = true;
    }
}

function ap_console_storage_directories(string $appPath): array
{
    return [
        $appPath . '/storage',
        $appPath . '/storage/cache',
        $appPath . '/storage/cache/views',
        $appPath . '/storage/logs',
        $appPath . '/storage/rate_limits',
        $appPath . '/storage/uploads',
        $appPath . '/storage/uploads/blog',
        $appPath . '/storage/avatars',
    ];
}

function ap_console_delete_files(string $dir, string $pattern): int
{
    if (!is_dir($dir)) {
        return 0;
    }

    $deleted = 0;
    $iterator = new RecursiveIteratorIterator(
        new RecursiveDirectoryIterator($dir, FilesystemIterator::SKIP_DOTS),
        RecursiveIteratorIterator::CHILD_FIRST
    );

    foreach ($iterator as $item) {
        if ($item->isFile() && preg_match($pattern, $item->getFilename())) {
            if (@unlink($item->getPathname())) {
                $deleted++;
            }
        }
    }

    return $deleted;
}

function ap_console_check(string $label, bool $ok): int
{
    echo ($ok ? '[OK] ' : '[FAIL] ') . $label . "\n";

    return $ok ? 0 : 1;
}

function ap_console_resolve_public_path(string $projectRoot, string $requestedPublicPath): string
{
    if ($requestedPublicPath === '') {
        return $projectRoot . '/public_html';
    }

    if (str_starts_with($requestedPublicPath, '/')) {
        return rtrim($requestedPublicPath, '/');
    }

    return rtrim($projectRoot . '/' . ltrim($requestedPublicPath, '/'), '/');
}

function ap_console_prepare_public_html(string $appPath, string $publicPath, bool $force): int
{
    $failed = 0;

    if (!is_dir($publicPath) && !@mkdir($publicPath, 0775, true)) {
        return ap_console_check("Create public directory {$publicPath}", false);
    }

    $failed += ap_console_check("Public directory {$publicPath}", is_dir($publicPath) && is_writable($publicPath));
    $failed += ap_console_write_file_if_needed(
        $publicPath . '/index.php',
        ap_console_public_index_template(),
        $force
    );
    $failed += ap_console_write_file_if_needed(
        $publicPath . '/bootstrap_paths.php',
        ap_console_public_bootstrap_paths_template(),
        $force
    );
    $failed += ap_console_write_file_if_needed(
        $publicPath . '/.htaccess',
        ap_console_public_htaccess_template(),
        $force
    );

    $uploadsLink = $publicPath . '/uploads';
    $uploadsTarget = $appPath . '/storage/uploads';
    if (!file_exists($uploadsLink) && !is_link($uploadsLink)) {
        $relativeTarget = ap_console_relative_path(dirname($uploadsLink), $uploadsTarget);
        if (!@symlink($relativeTarget, $uploadsLink)) {
            $failed += ap_console_check("Create uploads symlink {$uploadsLink} -> {$relativeTarget}", false);
        } else {
            $failed += ap_console_check("Create uploads symlink {$uploadsLink} -> {$relativeTarget}", true);
        }
    } else {
        $failed += ap_console_check("Uploads link exists {$uploadsLink}", true);
    }

    if (is_file($publicPath . '/index.html')) {
        echo "[INFO] Existing {$publicPath}/index.html detected.\n";
        echo "[INFO] Keep `DirectoryIndex index.php index.html` in .htaccess or rename index.html if hosting still serves a placeholder page.\n";
    }

    return $failed;
}

function ap_console_prepare_env_file(string $appPath, string $domain, string $siteName): int
{
    $envPath = $appPath . '/.env';
    $examplePath = $appPath . '/.env.example';

    if (is_file($envPath)) {
        $content = (string) file_get_contents($envPath);
        $content = ap_console_upsert_env_value($content, 'APP_URL', 'https://' . $domain);
        $content = ap_console_upsert_env_value($content, 'CORS_ALLOWED_ORIGINS', 'https://' . $domain);
        $content = ap_console_upsert_env_value($content, 'BRAND_NAME', $siteName);

        if (file_put_contents($envPath, $content, LOCK_EX) === false) {
            return ap_console_check("Update {$envPath}", false);
        }

        return ap_console_check("Update {$envPath}", true);
    }

    if (!is_file($examplePath)) {
        return ap_console_check('.env.example exists', false);
    }

    $content = (string) file_get_contents($examplePath);
    $content = ap_console_upsert_env_value($content, 'APP_URL', 'https://' . $domain);
    $content = ap_console_upsert_env_value($content, 'CORS_ALLOWED_ORIGINS', 'https://' . $domain);
    $content = ap_console_upsert_env_value($content, 'BRAND_NAME', $siteName);

    if ($content === null || file_put_contents($envPath, $content, LOCK_EX) === false) {
        return ap_console_check("Create {$envPath} from .env.example", false);
    }

    return ap_console_check("Create {$envPath} from .env.example", true);
}

function ap_console_upsert_env_value(string $content, string $key, string $value): string
{
    $line = $key . '=' . $value;
    $pattern = '/^' . preg_quote($key, '/') . '=.*/m';

    if (preg_match($pattern, $content) === 1) {
        return preg_replace($pattern, $line, $content) ?? $content;
    }

    return rtrim($content) . "\n" . $line . "\n";
}

function ap_console_ensure_app_key(string $appPath): int
{
    $envPath = $appPath . '/.env';
    if (!is_file($envPath)) {
        return ap_console_check('APP_KEY in .env', false);
    }

    $envContent = (string) file_get_contents($envPath);
    if (preg_match('/^APP_KEY=(.+)$/m', $envContent) === 1) {
        return ap_console_check('APP_KEY in .env', true);
    }

    return ap_console_app_key($appPath, []);
}

function ap_console_hosting_diagnostics(string $appPath, string $publicPath, string $domain): int
{
    $failed = 0;
    $projectRoot = dirname($appPath);
    $requiredPublicFiles = [
        $publicPath . '/index.php',
        $publicPath . '/bootstrap_paths.php',
        $publicPath . '/.htaccess',
    ];

    foreach ($requiredPublicFiles as $requiredPublicFile) {
        $failed += ap_console_check("Hosting file {$requiredPublicFile}", is_file($requiredPublicFile));
    }

    $htaccessContent = is_file($publicPath . '/.htaccess')
        ? (string) file_get_contents($publicPath . '/.htaccess')
        : '';

    $failed += ap_console_check(
        '.htaccess prefers index.php before index.html',
        str_contains($htaccessContent, 'DirectoryIndex index.php index.html')
    );
    $failed += ap_console_check(
        '.htaccess uses Apache 2.4 dotfile protection',
        str_contains($htaccessContent, 'Require all denied')
    );

    $cliOpenBaseDir = (string) ini_get('open_basedir');
    if ($cliOpenBaseDir === '' || str_contains($cliOpenBaseDir, $appPath)) {
        $failed += ap_console_check('CLI open_basedir allows app path', true);
    } else {
        $failed += ap_console_check('CLI open_basedir allows app path', false);
        echo "[FIX] Add {$appPath} to CLI open_basedir.\n";
    }

    $fpmPoolPath = '/etc/php/' . PHP_MAJOR_VERSION . '.' . PHP_MINOR_VERSION . '/fpm/pool.d/' . $domain . '.conf';
    if (is_file($fpmPoolPath) && is_readable($fpmPoolPath)) {
        $poolConfig = (string) file_get_contents($fpmPoolPath);
        $poolAllowsApp = str_contains($poolConfig, $appPath);
        $failed += ap_console_check("FPM pool open_basedir allows {$appPath}", $poolAllowsApp);
        if (!$poolAllowsApp) {
            echo "[FIX] Edit {$fpmPoolPath} and include {$appPath} in php_admin_value[open_basedir].\n";
            echo "[FIX] Example:\n";
            echo "      php_admin_value[open_basedir] = {$projectRoot}/public_html:{$projectRoot}/private:{$appPath}:/tmp\n";
            echo "[FIX] Then restart PHP-FPM, for example: sudo systemctl restart php" . PHP_MAJOR_VERSION . '.' . PHP_MINOR_VERSION . "-fpm\n";
        }
    } else {
        echo "[INFO] Could not read {$fpmPoolPath}. If HTTP 500 shows open_basedir errors, add {$appPath} to that domain's PHP-FPM pool config.\n";
    }

    if (is_file($publicPath . '/ob.php')) {
        echo "[WARN] Remove {$publicPath}/ob.php after diagnostics.\n";
    }

    return $failed;
}

function ap_console_write_file_if_needed(string $path, string $content, bool $force): int
{
    if (is_file($path) && !$force) {
        return ap_console_check("Keep existing {$path}", true);
    }

    if (file_put_contents($path, $content, LOCK_EX) === false) {
        return ap_console_check("Write {$path}", false);
    }

    return ap_console_check("Write {$path}", true);
}

function ap_console_relative_path(string $fromDir, string $targetPath): string
{
    $fromParts = array_values(array_filter(explode('/', trim(str_replace('\\', '/', $fromDir), '/')), 'strlen'));
    $targetParts = array_values(array_filter(explode('/', trim(str_replace('\\', '/', $targetPath), '/')), 'strlen'));

    while ($fromParts !== [] && $targetParts !== [] && $fromParts[0] === $targetParts[0]) {
        array_shift($fromParts);
        array_shift($targetParts);
    }

    return str_repeat('../', count($fromParts)) . implode('/', $targetParts);
}

function ap_console_public_index_template(): string
{
    return <<<'PHP'
<?php

require_once __DIR__ . '/bootstrap_paths.php';

$appPath = ap_resolve_app_path();

require_once $appPath . '/bootstrap/app.php';

ap_bootstrap_http_application($appPath, __DIR__);
PHP;
}

function ap_console_public_bootstrap_paths_template(): string
{
    return <<<'PHP'
<?php
/**
 * Resolve application root (folder that contains core/, mvc/, .env).
 * Default: sibling "app" next to this directory (public_html).
 * Override: APP_ROOT_OVERRIDE = absolute path to app/ (SetEnv / php-fpm / shell).
 */
declare(strict_types=1);

if (!function_exists('ap_resolve_app_path')) {
    function ap_resolve_app_path(): string
    {
        $override = $_SERVER['APP_ROOT_OVERRIDE'] ?? $_ENV['APP_ROOT_OVERRIDE'] ?? '';
        if ($override === '' && function_exists('getenv')) {
            $g = getenv('APP_ROOT_OVERRIDE');
            if ($g !== false && $g !== '') {
                $override = $g;
            }
        }
        $normalize = static function (string $path): string {
            $path = rtrim(str_replace('\\', '/', $path), '/');
            $realPath = realpath($path);

            return $realPath !== false ? str_replace('\\', '/', $realPath) : $path;
        };

        $isValidAppPath = static function (string $path): bool {
            return $path !== '' && is_file(rtrim($path, '/') . '/core/config/Env.php');
        };

        $override = $normalize((string) $override);
        if ($isValidAppPath($override)) {
            return $override;
        }

        $candidates = [];
        $addCandidate = static function (?string $path) use (&$candidates, $normalize): void {
            if (!is_string($path) || trim($path) === '') {
                return;
            }

            $normalized = $normalize($path);
            if (!in_array($normalized, $candidates, true)) {
                $candidates[] = $normalized;
            }
        };

        $scriptDir = $normalize(__DIR__);
        $documentRoot = isset($_SERVER['DOCUMENT_ROOT']) ? $normalize((string) $_SERVER['DOCUMENT_ROOT']) : '';
        $scriptFilename = isset($_SERVER['SCRIPT_FILENAME']) ? $normalize(dirname((string) $_SERVER['SCRIPT_FILENAME'])) : '';

        $addCandidate($scriptDir . '/app');
        $addCandidate(dirname($scriptDir) . '/app');
        $addCandidate(dirname(dirname($scriptDir)) . '/app');

        if ($documentRoot !== '') {
            $addCandidate($documentRoot . '/app');
            $addCandidate(dirname($documentRoot) . '/app');
            $addCandidate(dirname(dirname($documentRoot)) . '/app');
        }

        if ($scriptFilename !== '') {
            $addCandidate($scriptFilename . '/app');
            $addCandidate(dirname($scriptFilename) . '/app');
            $addCandidate(dirname(dirname($scriptFilename)) . '/app');
        }

        foreach ($candidates as $candidate) {
            if ($isValidAppPath($candidate)) {
                return $candidate;
            }
        }

        return $normalize(dirname(__DIR__) . '/app');
    }
}
PHP;
}

function ap_console_public_htaccess_template(): string
{
    return <<<'APACHE'
DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP:X-Forwarded-Proto} !^https$
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    RewriteCond %{REQUEST_URI} ^/(baza\.php|adminer\.php|phpmyadmin) [NC]
    RewriteRule ^ - [L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L]
</IfModule>

Options -Indexes

<FilesMatch "^\.">
    Require all denied
</FilesMatch>
APACHE;
}

function ap_console_parse_options(array $args): array
{
    $options = [];

    foreach ($args as $arg) {
        if (!str_starts_with($arg, '--')) {
            continue;
        }

        $arg = substr($arg, 2);
        if (str_contains($arg, '=')) {
            [$key, $value] = explode('=', $arg, 2);
            $options[$key] = $value;
        } else {
            $options[$arg] = true;
        }
    }

    return $options;
}
